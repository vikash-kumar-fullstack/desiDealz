<% if(msg && msg.length){ %>
  <div class="alert success">
    <span><%= msg %></span>
    <button onclick="this.parentElement.style.display='none'">✕</button>
  </div>
<% } %>

<% if(error && error.length){ %>
  <div class="alert error">
    <span><%= error %></span>
    <button onclick="this.parentElement.style.display='none'">✕</button>
  </div>
<% } %>