<header class="navbar">

  <!-- LOGO -->
  <div class="nav-left">
    <a href="/product" class="logo">
      🛍️ DesiDealz
    </a>
  </div>

  <!-- NAV LINKS -->
  <nav class="nav-center">
    <a href="/product">Home</a>
    <a href="/product/new">Sell</a>
  </nav>

  <!-- RIGHT SIDE -->
  <div class="nav-right">

    <!-- CART -->
    <a href="/cart" class="cart">
      🛒
      <% if (cartCount > 0) { %>
        <span class="cart-badge">
          <%= cartCount > 99 ? '99+' : cartCount %>
        </span>
      <% } %>
    </a>

    <!-- AUTH -->
    <% if(!curUser){ %>
      <a href="/user/login" class="btn btn-primary">Login</a>
    <% } else { %>
      <a href="/user/logout" class="btn">Logout</a>
    <% } %>

  </div>

</header>