<% layout("/layouts/boilerplate") -%>

<section class="auth-container">

  <div class="auth-card">

    <h1>Welcome Back 👋</h1>
    <p class="auth-sub">Login to continue</p>

    <form action="/user/login" method="post">

      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Enter username" required class="input">
      </div>

      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Enter password" required class="input">
      </div>

      <button class="btn btn-primary auth-btn">Login</button>

    </form>

    <p class="auth-switch">
      Don’t have an account? <a href="/user/signup">Sign Up</a>
    </p>

  </div>

</section>