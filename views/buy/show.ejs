<% layout("/layouts/boilerplate") -%>

<div class="container mt-5 mb-5 d-flex justify-content-center">
  <div class="order-confirmation-wrapper w-100" style="max-width: 700px;">
    
    <div class="text-center mb-4">
      <div class="success-icon mb-3">✓</div>
      <h1 class="fw-bold">Order Summary</h1>
      <p class="text-muted">Review your items before proceeding to payment.</p>
    </div>

    <div class="card order-card shadow-sm border-0 p-4 p-md-5" style="background: #ffffff; border-radius: 16px;">
      
      <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h5 class="mb-0 fw-bold text-muted">Order ID:</h5>
        <span class="fs-6 fw-semibold text-dark user-select-all"><%= order._id %></span>
      </div>

      <h5 class="fw-bold mb-3">Items Ordered</h5>
      <div class="order-items-container mb-4">
        <% for (let item of order.items) { %>
          <div class="order-item d-flex align-items-center py-3 border-bottom" style="gap: 15px;">
            
            <div class="bg-light rounded border d-flex justify-content-center align-items-center" style="width: 80px; height: 80px; min-width: 80px; overflow: hidden; padding: 8px;">
              <img src="<%= item.product.image.url || item.product.image %>" style="width: 100%; height: 100%; max-width: 100%; max-height: 100%; object-fit: contain;" alt="<%= item.product.title %>">
            </div>
            
            <div class="flex-grow-1">
              <h6 class="mb-1 fw-bold text-dark"><%= item.product.title %></h6>
              <p class="mb-0 text-muted small">Qty: <%= item.quantity %></p>
            </div>
            
            <div class="text-end">
              <p class="mb-0 fw-bold text-dark fs-5">₹<%= (item.product.price * item.quantity).toLocaleString('en-IN') %></p>
              <% if (item.quantity > 1) { %>
                <small class="text-muted" style="font-size: 0.75rem;">(₹<%= item.product.price.toLocaleString('en-IN') %> each)</small>
              <% } %>
            </div>
            
          </div>
        <% } %>
      </div>

      <div class="d-flex justify-content-between align-items-center bg-light p-4 rounded-3 mb-4 border">
        <h4 class="mb-0 fw-bold text-dark">Total Amount</h4>
        <h3 class="mb-0 fw-bold text-primary">₹<%= order.total.toLocaleString('en-IN') %></h3>
      </div>

      <form action="/payment" method="post" class="mt-2">
        <input type="hidden" name="price" value="<%= order.total %>">
        <button type="submit" class="btn btn-primary w-100 py-3 fs-5 fw-semibold rounded-3 mb-3 shadow-sm">
          Proceed to Secure Payment 🔒
        </button>
      </form>
      
      <div class="text-center">
        <a href="/" class="text-decoration-none text-muted fw-medium">← Cancel & Continue Shopping</a>
      </div>

    </div>
  </div>
</div>