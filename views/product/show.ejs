<% layout("/layouts/boilerplate") -%>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<section class="product-detail">

  <!-- 🔥 TOP SECTION -->
  <div class="product-layout">

    <!-- IMAGE -->
    <div class="product-image">
      <img src="<%= data.image.url %>" alt="product">
    </div>

    <!-- DETAILS -->
    <div class="product-info">

      <h1><%= data.title %></h1>

      <p class="price">₹ <%= data.price.toLocaleString("en-IN") %></p>

      <p class="desc"><%= data.description %></p>

      <p class="meta">Owner: <%= data.owner.username %></p>
      <p class="meta">Location: <%= data.location %></p>

      <!-- ACTIONS -->
      <% if(curUser && curUser._id.equals(data.owner._id)){ %>
        <div class="actions">
          <a href="/product/<%= data.id %>/edit" class="btn">Edit</a>
          <form action="/product/<%= data.id %>/delete?_method=DELETE" method="post">
            <button class="btn">Delete</button>
          </form>
        </div>
      <% } else { %>
        <div class="actions">
          <a href="/product/<%= data.id %>/buy" class="btn btn-primary">Buy Now</a>
          <form action="/product/<%= data.id %>/cart" method="post">
            <button class="btn">Add to Cart</button>
          </form>
        </div>
      <% } %>

    </div>

  </div>

</section>


<!-- 🔥 REVIEW SECTION -->
<section class="review-section">

  <% if(curUser){ %>
    <div class="review-form">
      <h2>Leave a Review</h2>

      <form action="/product/<%=data.id%>/review" method="post">

        <fieldset class="starability-heart">
          <input type="radio" name="review[rating]" value="1" checked />
          <input type="radio" name="review[rating]" value="2" />
          <input type="radio" name="review[rating]" value="3" />
          <input type="radio" name="review[rating]" value="4" />
          <input type="radio" name="review[rating]" value="5" />
        </fieldset>

        <textarea name="review[comment]" placeholder="Write your review..." required></textarea>

        <button class="btn btn-primary">Submit</button>

      </form>
    </div>
  <% } %>


  <% if(data.review.length > 0){ %>
    <div class="reviews">
      <h2>Reviews</h2>

      <div class="grid grid-3">
        <% for (let review of data.review) { %>
          <div class="card-modern">

            <div class="card-content">
              <h4>@<%=review.author.username%></h4>
              <p>⭐ <%= review.rating %>/5</p>
              <p><%= review.comment %></p>

              <form action="/product/<%=data.id%>/review/<%=review.id%>?_method=DELETE" method="post">
                <button class="btn">Delete</button>
              </form>
            </div>

          </div>
        <% } %>
      </div>
    </div>
  <% } %>

</section>


<!-- 🔥 MAP SECTION -->
<section class="map-section">
  <h2>Location</h2>

  <div id="map-container">
    <div id="map"></div>
    <div id="map-loading">Loading map...</div>
  </div>
</section>
<script>
document.addEventListener("DOMContentLoaded", async () => {
  const locationName = "<%= data.location %>";

  const map = L.map("map").setView([20.5937, 78.9629], 5);

  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    attribution: "© OpenStreetMap contributors",
  }).addTo(map);

  try {
    const res = await fetch(
      `https://nominatim.openstreetmap.org/search?format=json&q=${locationName}`
    );
    const data = await res.json();

    if (data.length > 0) {
      const lat = data[0].lat;
      const lon = data[0].lon;

      map.setView([lat, lon], 13);

      L.marker([lat, lon])
        .addTo(map)
        .bindPopup(locationName)
        .openPopup();
    }
  } catch (err) {
    console.log("Map error:", err);
  }
});
</script>